# Google Sheets API credentials for RSVP storage
#
# Setup steps:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or use existing)
# 3. Enable the Google Sheets API
# 4. Create a Service Account (IAM & Admin > Service Accounts)
# 5. Create a key for the service account (JSON format)
# 6. Create a Google Sheet and share it with the service account email
# 7. Add a header row: Timestamp | Name | Email | Attending | Guests | Dietary | Message
# 8. Copy the Sheet ID from the URL (the long string between /d/ and /edit)


GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-here
